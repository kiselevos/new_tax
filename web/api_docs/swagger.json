{
  "endpoints": [
    {
      "group": "public",
      "method": "POST",
      "path": "/api/{version}/calc",
      "description": "Базовый расчёт НДФЛ по прогрессивной шкале. Принимает оклад в копейках, возвращает помесячную детализацию.",
      "example_request": {"gross_salary": 10000000},
      "example_response": {
        "gross_salary": 10000000,
        "annual_gross_income": 120000000,
        "annual_net_income": 104400000,
        "annual_tax_amount": 15600000,
        "monthly_details": [
          {
            "month": "2025-01-01T00:00:00Z",
            "monthly_gross_income": 10000000,
            "monthly_net_income": 8700000,
            "monthly_tax_amount": 1300000,
            "tax_rate": 13
          },
          "... 11 more months ..."
        ]
      }
    },
    {
      "group": "private",
      "method": "POST",
      "path": "/api/{version}/private-calc",
      "description": "Расширенный расчёт — трудовой договор (ТД). Поддерживает районный коэффициент, северную надбавку, льготы, налоговый нерезидентство, премии по месяцам и налоговые вычеты. Поле employment_type: \"TD\" (по умолчанию), \"GPH\", \"SELF_EMPLOYED\".",
      "example_request": {
        "gross_salary": 20000000,
        "employment_type": "TD",
        "territorial_multiplier": 120,
        "northern_coefficient": 150,
        "start_date": "2025-01-01",
        "has_tax_privilege": false,
        "monthly_bonuses": [0, 0, 0, 0, 0, 0, 200000000, 0, 0, 0, 0, 0],
        "children_count": 2
      },
      "example_response": {
        "gross_salary": 20000000,
        "employment_type": "TD",
        "territorial_multiplier": 120,
        "northern_coefficient": 150,
        "annual_gross_income": 484000000,
        "annual_net_income": 421272000,
        "annual_tax_amount": 62728000,
        "annual_pfr": 106480000,
        "annual_foms": 24684000,
        "annual_fss": 14276000,
        "monthly_details": [
          {
            "month": "2025-01-01T00:00:00Z",
            "monthly_gross_income": 36000000,
            "monthly_net_income": 31320000,
            "monthly_tax_amount": 4680000,
            "tax_rate": 13,
            "monthly_pfr": 7920000,
            "monthly_foms": 1836000,
            "monthly_fss": 1044000
          },
          "... 11 more months ..."
        ]
      }
    },
    {
      "group": "private",
      "method": "POST",
      "path": "/api/{version}/private-calc",
      "description": "Расширенный расчёт — договор ГПХ. НДФЛ по той же прогрессивной шкале, ФСС не начисляется. Территориальный коэффициент и северная надбавка не применяются.",
      "example_request": {
        "gross_salary": 15000000,
        "employment_type": "GPH",
        "start_date": "2025-01-01"
      },
      "example_response": {
        "gross_salary": 15000000,
        "employment_type": "GPH",
        "annual_gross_income": 180000000,
        "annual_net_income": 156600000,
        "annual_tax_amount": 23400000,
        "annual_pfr": 39600000,
        "annual_foms": 9180000,
        "annual_fss": 0,
        "monthly_details": [
          {
            "month": "2025-01-01T00:00:00Z",
            "monthly_gross_income": 15000000,
            "monthly_net_income": 13050000,
            "monthly_tax_amount": 1950000,
            "tax_rate": 13,
            "monthly_pfr": 3300000,
            "monthly_foms": 765000,
            "monthly_fss": 0
          },
          "... 11 more months ..."
        ]
      }
    },
    {
      "group": "private",
      "method": "POST",
      "path": "/api/{version}/private-calc",
      "description": "Расширенный расчёт — самозанятый (НПД). Ставка 4% при доходе от физлица, 6% — от организации/ИП. Страховые взносы не начисляются. Поле npd_income_source: \"INDIVIDUAL\" (4%) или \"LEGAL_ENTITY\" (6%). Опциональный регистрационный вычет 10 000 ₽ — has_registration_deduction: true.",
      "example_request": {
        "gross_salary": 5000000,
        "employment_type": "SELF_EMPLOYED",
        "npd_income_source": "INDIVIDUAL",
        "has_registration_deduction": true,
        "start_date": "2025-01-01"
      },
      "example_response": {
        "gross_salary": 5000000,
        "employment_type": "SELF_EMPLOYED",
        "annual_gross_income": 60000000,
        "annual_net_income": 58200000,
        "annual_tax_amount": 1800000,
        "annual_pfr": 0,
        "annual_foms": 0,
        "annual_fss": 0,
        "npd_limit_exceeded": false,
        "monthly_details": [
          {
            "month": "2025-01-01T00:00:00Z",
            "monthly_gross_income": 5000000,
            "monthly_net_income": 4850000,
            "monthly_tax_amount": 150000,
            "tax_rate": 4,
            "npd_deduction_used": 50000,
            "monthly_pfr": 0,
            "monthly_foms": 0,
            "monthly_fss": 0
          },
          "... 11 more months ..."
        ]
      }
    }
  ]
}
