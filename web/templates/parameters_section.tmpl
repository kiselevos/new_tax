{{define "parameters_section"}}
<!-- Блок с параметрами расчета -->
<div class="parameters-card">
    <div class="parameters-header">
        <h2>Ваши параметры</h2>
    </div>
    <div class="parameters-grid">
        <div class="parameter-item">
            <span class="parameter-label">Период:</span>
            <span class="parameter-value">
                {{if .MonthlyDetails}}
                    {{$first := index .MonthlyDetails 0}}
                    {{$last := index .MonthlyDetails (sub (len .MonthlyDetails) 1)}}
                    {{russianMonth $first.Month}} – {{russianMonth $last.Month}}
                {{else}}
                    не указан
                {{end}}
            </span>
        </div>
        
        <div class="parameter-item">
            <span class="parameter-label">Оклад:</span>
            <span class="parameter-value">{{.GrossSalary | fmtMoney}}</span>
        </div>
        
        {{if ne .TerritorialMult 100}}
        <div class="parameter-item">
            <span class="parameter-label">Территориальный коэффициент:</span>
            <span class="parameter-value">×{{printf "%.2f" (divf .TerritorialMult 100.0)}}</span>
        </div>
        {{end}}
        
        {{if ne .NorthernCoeff 100}}
        <div class="parameter-item">
            <span class="parameter-label">Северная надбавка:</span>
            <span class="parameter-value">{{.NorthernCoeff | minus100}}%</span>
        </div>
        {{end}}
        
        {{if .HasTaxPrivilege}}
        <div class="parameter-item">
            <span class="parameter-label">Льготы:</span>
            <span class="parameter-value">для силовых структур</span>
        </div>
        {{end}}
        
        {{if .IsNotResident}}
        <div class="parameter-item">
            <span class="parameter-label">Статус:</span>
            <span class="parameter-value">Налоговый нерезидент</span>
        </div>
        {{end}}
    </div>
</div>
{{end}}