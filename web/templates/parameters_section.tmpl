{{define "parameters_section"}}
<!-- Блок с параметрами расчета -->
<div class="parameters-card">
    <div class="parameters-header">
        <div class="parameters-icon">ℹ️</div>
        <h2>Параметры расчета</h2>
    </div>

    <div class="parameters-grid">
        <div class="parameter-item">
            <span class="parameter-label">Период:</span>
            <span class="parameter-value">
                {{if .MonthlyDetails}}
                    {{$first := index .MonthlyDetails 0}}
                    {{$last := index .MonthlyDetails (sub (len .MonthlyDetails) 1)}}
                    {{russianMonth $first.Month}} – {{russianMonth $last.Month}}
                {{else}}
                    не указан
                {{end}}
            </span>
        </div>

        <div class="parameter-item">
            <span class="parameter-label">Оклад:</span>
            <span class="parameter-value">{{.GrossSalary | fmtMoney}}</span>
        </div>

        {{if ne .TerritorialMult 100}}
        <div class="parameter-item">
            <span class="parameter-label">Территориальный коэффициент:</span>
            <span class="parameter-value">×{{printf "%.2f" (divf .TerritorialMult 100.0)}}</span>
        </div>
        {{end}}

        {{if ne .NorthernCoeff 100}}
        <div class="parameter-item">
            <span class="parameter-label">Северная надбавка:</span>
            <span class="parameter-value">{{.NorthernCoeff | minus100}}%</span>
        </div>
        {{end}}

        {{if .IsGPH}}
        <div class="parameter-item">
            <span class="parameter-label">Договор:</span>
            <span class="parameter-value">ГПХ</span>
        </div>
        {{end}}

        {{if .HasTaxPrivilege}}
        <div class="parameter-item">
            <span class="parameter-label">Льготы:</span>
            <span class="parameter-value">для силовых структур</span>
        </div>
        {{end}}

        {{if .IsNotResident}}
        <div class="parameter-item">
            <span class="parameter-label">Статус:</span>
            <span class="parameter-value">Налоговый нерезидент</span>
        </div>
        {{end}}

        {{/* ===== Изменения ставки НДФЛ (в одном блоке) ===== */}}
{{ $prev := 0 }}
{{ $hasChange := false }}

{{/* Сначала проверим, есть ли изменения */}}
{{ range $i, $m := .MonthlyDetails }}
  {{ if eq $i 0 }}
    {{ $prev = $m.TaxRate }}
  {{ else if ne $prev $m.TaxRate }}
    {{ $hasChange = true }}
  {{ end }}
  {{ $prev = $m.TaxRate }}
{{ end }}

{{ if $hasChange }}
<div class="parameter-item parameter-item--alert">
  <span class="parameter-label">Ставка НДФЛ (изменения):</span>
  <div class="parameter-value">
    {{ $prev := 0 }}
    {{ range $i, $m := .MonthlyDetails }}
      {{ if eq $i 0 }}
        {{ $prev = $m.TaxRate }}
      {{ else if ne $prev $m.TaxRate }}
        <div class="rate-transition">
          <span class="rate-pill old">{{$prev}}%</span>
          <span class="rate-arrow-icon">→</span>
          <span class="rate-pill new">{{$m.TaxRate}}%</span>
          <span class="rate-month-name">с {{russianMonth $m.Month}}</span>
        </div>
      {{ end }}
      {{ $prev = $m.TaxRate }}
    {{ end }}
  </div>
</div>
{{ end }}
{{/* ===== /конец блока изменений ===== */}}

    </div>

    <!-- Кнопка открытия панели редактирования -->
    <div class="edit-params-toggle-wrap">
        <button type="button" id="edit-params-toggle" class="edit-params-toggle">
            ✏️ Изменить параметры
        </button>
    </div>

    <!-- Панель редактирования параметров -->
    <div id="edit-params-panel" class="edit-params-panel">
        <div class="edit-params-grid">

            <!-- Оклад -->
            <div class="edit-field">
                <label class="edit-label">Оклад</label>
                <div class="edit-salary-wrap">
                    <input type="text" name="grossSalary"
                           value="{{fmtMoneyRaw .GrossSalary}}"
                           class="edit-input edit-input--salary"
                           placeholder="50 000">
                    <span class="edit-currency">₽</span>
                </div>
            </div>

            <!-- Месяц начала -->
            <div class="edit-field">
                <label class="edit-label">Месяц начала</label>
                <select name="startDate" class="edit-select">
                    {{range .Months}}
                    <option value="{{.Value}}"
                        {{if eq .Value (printf "%02d" $.StartMonthNum)}}selected{{end}}>
                        {{.Label}}
                    </option>
                    {{end}}
                </select>
            </div>

            <!-- Территориальный коэффициент -->
            <div class="edit-field">
                <label class="edit-label">
                    Территориальный коэффициент
                    <a href="/regional-info" target="_blank" rel="noopener" class="edit-label-link">?</a>
                </label>
                <select name="territorialMultiplier" class="edit-select">
                    <option value="100" {{if eq (toInt $.TerritorialMult) 100}}selected{{end}}>нет</option>
                    {{range .Territorial}}
                    <option value="{{.Value}}"
                        {{if eq .Value (toInt $.TerritorialMult)}}selected{{end}}>
                        {{.Label}}
                    </option>
                    {{end}}
                </select>
            </div>

            <!-- Северная надбавка -->
            <div class="edit-field">
                <label class="edit-label">
                    Северная надбавка
                    <a href="/regional-info" target="_blank" rel="noopener" class="edit-label-link">?</a>
                </label>
                <select name="northernCoefficient" class="edit-select">
                    <option value="100" {{if eq (toInt $.NorthernCoeff) 100}}selected{{end}}>нет</option>
                    {{range .Northern}}
                    <option value="{{.Value}}"
                        {{if eq .Value (toInt $.NorthernCoeff)}}selected{{end}}>
                        {{.Label}}
                    </option>
                    {{end}}
                </select>
            </div>

            <!-- Тип занятости -->
            <div class="edit-field edit-field--full">
                <label class="edit-label">Тип занятости</label>
                <div class="edit-checkboxes">
                    <label class="edit-checkbox-item">
                        <input type="radio" name="employmentType" value="TD"
                               {{if .IsGPH}}{{else}}checked{{end}}>
                        Трудовой договор
                    </label>
                    <label class="edit-checkbox-item">
                        <input type="radio" name="employmentType" value="GPH"
                               {{if .IsGPH}}checked{{end}}>
                        Договор ГПХ
                    </label>
                </div>
            </div>

            <!-- Льготы -->
            <div class="edit-field edit-field--full">
                <label class="edit-label">
                    Особые условия
                    <a href="/special-tax-modes" target="_blank" rel="noopener" class="edit-label-link">?</a>
                </label>
                <div class="edit-checkboxes">
                    <label class="edit-checkbox-item">
                        <input type="checkbox" name="hasTaxPrivilege"
                               class="edit-exclusive"
                               {{if .HasTaxPrivilege}}checked{{end}}>
                        Льготное налогообложение (силовые структуры)
                    </label>
                    <label class="edit-checkbox-item">
                        <input type="checkbox" name="isNotResident"
                               class="edit-exclusive"
                               {{if .IsNotResident}}checked{{end}}>
                        Налоговый нерезидент
                    </label>
                </div>
            </div>

        </div>

        <div class="edit-params-actions">
            <button type="submit" class="edit-params-submit">Пересчитать →</button>
            <button type="button" id="edit-params-cancel" class="edit-params-cancel">Отмена</button>
        </div>
    </div>
</div>
{{end}}
