{{define "result"}}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Результаты расчёта</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="stylesheet" href="/static/result.css">
    <link rel="stylesheet" href="/static/monthly_accordion.css">
    <link rel="stylesheet" href="/static/parameters_section.css">
    <link rel="stylesheet" href="/static/summary_section.css">
    <link rel="stylesheet" href="/static/employer_contrib.css">

    <!-- favicon -->
  <link rel="icon" href="/static/favicon.ico" type="image/x-icon">
  <link rel="shortcut icon" href="/static/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="container">
        <!-- Предупреждение -->
        {{if .ShowWarning}}
            {{template "warning" .}}
        {{end}}

        <!-- Блок с параметрами расчета --->
        {{template "parameters_section" .}}

        <!-- Блок с результатами расчета --->

        <!-- Основная сводка -->
        {{template "summary_section" .}}

        <!-- Вкладка: взносы работодателя -->
        {{template "employer_contributions" .}}

        <!-- Помесячная детализация -->
        {{template "monthly_accordion" .}}

        <!-- Кнопка -->
        <div class="actions">
            <a href="/" class="primary-button">
                Сделать новый расчёт
            </a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const headers = document.querySelectorAll('.accordion-header');
            headers.forEach(h => h.addEventListener('click', () => h.parentElement.classList.toggle('active')));
        });
    </script>
</body>
</html>
{{end}}