{{define "result"}}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Результат расчёта НДФЛ — {{fmtMoney .GrossSalary}} в месяц</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="stylesheet" href="/static/result.css">
    <link rel="stylesheet" href="/static/monthly_accordion.css">
    <link rel="stylesheet" href="/static/parameters_section.css">
    <link rel="stylesheet" href="/static/summary_section.css">
    <link rel="stylesheet" href="/static/employer_contrib.css">
    <link rel="stylesheet" href="/static/bonuses.css">

    <!-- favicon -->
  <link rel="icon" href="/static/favicon.ico" type="image/x-icon">
  <link rel="shortcut icon" href="/static/favicon.ico" type="image/x-icon">
</head>
<body>
<form id="bonuses-form" method="POST" action="/calculate">
    <!-- Скрытые поля: параметры исходного расчёта -->
    <input type="hidden" name="grossSalary" value="{{fmtMoneyRaw .GrossSalary}}">
    <input type="hidden" name="startDate" value="{{.StartMonthNum}}">
    <input type="hidden" name="territorialMultiplier" value="{{.TerritorialMult}}">
    <input type="hidden" name="northernCoefficient" value="{{.NorthernCoeff}}">
    {{if .HasTaxPrivilege}}<input type="hidden" name="hasTaxPrivilege" value="1">{{end}}
    {{if .IsNotResident}}<input type="hidden" name="isNotResident" value="1">{{end}}

    <div class="container">
        <!-- Предупреждение -->
        {{if .ShowWarning}}
            {{template "warning" .}}
        {{end}}

        <!-- Блок с параметрами расчета --->
        {{template "parameters_section" .}}

        <!-- Блок с результатами расчета --->

        <!-- Основная сводка -->
        {{template "summary_section" .}}

        <!-- Вкладка: взносы работодателя -->
        {{template "employer_contributions" .}}

        <!-- Помесячная детализация -->
        {{template "monthly_accordion" .}}

        <!-- Кнопки -->
        <div class="actions actions--result">
            <a href="/" class="back-button">
                ← Назад к калькулятору
            </a>
            <button type="submit" class="bonus-recalc-btn" id="bonus-recalc-btn">
                Пересчитать с премиями →
            </button>
        </div>
    </div>

    <footer class="site-footer">
        <div class="footer-links">
            <a class="footer-link" href="/about">О проекте</a>
            <a class="footer-link" href="/api-docs">API для разработчиков</a>
        </div>
        <div class="footer-copy">© 2025 Калькулятор НДФЛ</div>
    </footer>

    <!-- Липкая панель пересчёта (появляется при вводе премий) -->
    <div class="bonus-sticky-bar" id="bonus-sticky-bar">
        <div class="bonus-sticky-inner">
            <span class="bonus-sticky-label" id="bonus-sticky-label">Пересчитать с 1 премией</span>
            <button type="submit" class="bonus-sticky-btn">Пересчитать →</button>
        </div>
    </div>
</form>

    <script src="/static/script.js"></script>
</body>
</html>
{{end}}