{{define "result"}}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Результаты расчёта</title>
    <link rel="stylesheet" href="/static/style.css">
    <style>
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        .results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        .back-button { background: #6c757d; color: white; padding: 10px 20px; border-radius: 4px; border: none; cursor: pointer; }
        .primary-button { background: #007bff; color: white; padding: 12px 24px; border-radius: 4px; border: none; cursor: pointer; font-size: 16px; }
        .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 2rem 0; }
        .summary-card { background: #f8f9fa; padding: 1.5rem; border-radius: 8px; text-align: center; }
        .summary-value { font-size: 1.5rem; font-weight: bold; color: #007bff; margin: 0.5rem 0; }
        .accordion { margin: 2rem 0; }
        .accordion-item { border: 1px solid #dee2e6; border-radius: 4px; margin-bottom: 0.5rem; }
        .accordion-header { background: #f8f9fa; padding: 1rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
        .accordion-content { padding: 1rem; background: white; display: none; }
        .accordion-item.active .accordion-content { display: block; }
        .monthly-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; }
        .actions { text-align: center; margin-top: 2rem; }
    </style>
</head>
<body>
    <div class="container">
        <!-- Заголовок -->
        <div class="results-header">
            <h1>Результаты расчёта</h1>
            <button onclick="window.location.href='/'" class="back-button">
                Новый расчёт
            </button>
        </div>

        <!-- Основная сводка -->
        {{template "summary_section" .}}

        <!-- Помесячная детализация -->
        {{template "monthly_accordion" .}}

        <!-- Кнопка -->
        <div class="actions">
            <button onclick="window.location.href='/'" class="primary-button">
                Сделать новый расчёт
            </button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const headers = document.querySelectorAll('.accordion-header');
            headers.forEach(h => h.addEventListener('click', () => h.parentElement.classList.toggle('active')));
        });
    </script>
</body>
</html>
{{end}}

{{define "summary_section"}}
<div class="summary-grid">
    <div class="summary-card">
        <div>Оклад</div>
        <div class="summary-value">{{fmtMoney .GrossSalary}}</div>
        <small>в месяц</small>
    </div>
    <div class="summary-card">
        <div>Годовой доход</div>
        <div class="summary-value">{{fmtMoney .AnnualGrossIncome}}</div>
        <small>за период</small>
    </div>
    <div class="summary-card">
        <div>Налог НДФЛ</div>
        <div class="summary-value">{{fmtMoney .AnnualTaxAmount}}</div>
        <small>всего уплачено</small>
    </div>
    <div class="summary-card">
        <div>Чистый доход</div>
        <div class="summary-value">{{fmtMoney .AnnualNetIncome}}</div>
        <small>«на руки»</small>
    </div>
</div>
{{end}}

{{define "monthly_accordion"}}
<div class="accordion">
    <h2>Помесячная детализация</h2>
    {{range $i, $m := .MonthlyDetails}}
    <div class="accordion-item {{if eq $i 0}}active{{end}}">
        <div class="accordion-header">
            <span><strong>{{$m.Month.AsTime.Format "January 2006"}}</strong></span>
            <span>{{$m.MonthlyNetIncome}}</span>
        </div>
        <div class="accordion-content">
            <div class="monthly-grid">
                <div><strong>Доход:</strong><br>{{fmtMoney $m.MonthlyGrossIncome}}</div>
                <div><strong>Налог:</strong><br>{{fmtMoney $m.MonthlyTaxAmount}}</div>
                <div><strong>Ставка:</strong><br>{{$m.TaxRate}}%</div>
                <div><strong>Чистый доход:</strong><br>{{fmtMoney $m.MonthlyNetIncome}}</div>
                <div><strong>Накопленный доход:</strong><br>{{fmtMoney $m.AnnualGrossIncome}}</div>
                <div><strong>Накопленный налог:</strong><br>{{fmtMoney $m.AnnualTaxAmount}}</div>
            </div>
        </div>
    </div>
    {{end}}
</div>
{{end}}
