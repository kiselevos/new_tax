{{define "api-docs"}}
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Open API калькулятор НДФЛ</title>
  <meta name="description" content="Документация API для расчёта НДФЛ: эндпоинты, параметры и примеры запросов.">
    <link rel="stylesheet" href="/static/style.css">
  <link rel="stylesheet" href="/static/info-pages.css">
  
  <!-- Инлайн-стили для блоков с кодом -->
  <style>
    .code-container {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        background: #fafafa;
        border-radius: 6px;
        margin: 0;
        max-width: 100%;
        scrollbar-width: thin;
        scrollbar-color: #ccc #fafafa;
    }
    .code-container pre {
        margin: 0;
        padding: 15px;
        background: transparent;
        color: #333;
        font-size: 14px;
        line-height: 1.4;
        min-width: min-content;
        white-space: pre;
        font-family: 'Courier New', monospace;
    }
    /* Стилизация скроллбара для Webkit */
    .code-container::-webkit-scrollbar {
        height: 8px;
    }
    .code-container::-webkit-scrollbar-track {
        background: #fafafa;
        border-radius: 0 0 6px 6px;
    }
    .code-container::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }
    .code-container::-webkit-scrollbar-thumb:hover {
        background: #aaa;
    }
  </style>
  
  <link rel="icon" href="/static/favicon.ico" type="image/x-icon">
  <link rel="shortcut icon" href="/static/favicon.ico" type="image/x-icon">
</head>
<body>
<div class="info-page">
<div class="api-page">
    <h1 class="info-page-title">API — публичный интерфейс калькулятора НДФЛ</h1>

    <p class="info-page-subtitle">
        Здесь собрана документация по открытому API сервиса для расчёта НДФЛ 
        по прогрессивной шкале. Данные не сохраняются, вычисления выполняются в реальном времени.
    </p>

    <!-- Текущая версия -->
    <div class="info-card">
        <div class="api-version">
            <h2 class="info-card-title">
                Текущая версия API
                <span class="api-version-tag">{{ .ApiVers }}</span>
            </h2>
        </div>
    </div>

    <!-- PUBLIC API -->
    <div class="info-card">
        <h2 class="info-card-title">Публичные методы</h2>

        {{ range .Endpoints }}
            {{ if eq .Group "public" }}

            <div class="info-note" style="margin-top: 1rem;">
                <strong>{{ .Method }}</strong>  
                <code>{{ .Path }}</code>
            </div>

            <p class="info-card-text">{{ .Description }}</p>

            <div class="info-example">
                <strong>Полный запрос:</strong>
                <div class="code-container">
                    <pre>{{ .ExampleRequestFull }}</pre>
                </div>
            </div>

            <div class="info-example">
                <strong>Минимальный запрос:</strong>
                <div class="code-container">
                    <pre>{{ .ExampleRequestLite }}</pre>
                </div>
            </div>

            <div class="info-example">
                <strong>Пример ответа:</strong>
                <div class="code-container">
                    <pre>{{ .ExampleResponse }}</pre>
                </div>
            </div>

            {{ end }}
        {{ end }}
    </div>

    <!-- Примеры вызова -->
    <div class="info-card">
        <h2 class="info-card-title">Примеры вызова API</h2>

        <div class="info-example">
            <strong>curl:</strong>
            <div class="code-container">
                <pre>curl -X POST https://calculator-ndfl.ru/api/{{ .ApiVers }}/calc \
  -H "Content-Type: application/json" \
  -d '{"gross_salary": 120000}'</pre>
            </div>
        </div>

        <div class="info-example">
            <strong>JavaScript:</strong>
            <div class="code-container">
                <pre>fetch("/api/{{ .Ap }}/calc", {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({ gross_salary: 120000 })
})
  .then(r => r.json())
  .then(console.log)
  .catch(console.error);</pre>
            </div>
        </div>
    </div>
</div>
</div>
<div class="info-button-container">
      <button onclick="window.location.href='/'" class="info-button">Вернуться к калькулятору</button>
    </div>
</body>
</html>
{{ end }}