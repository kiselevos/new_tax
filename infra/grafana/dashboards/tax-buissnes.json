{
  "id": null,
  "uid": "tax-business",
  "title": "Tax Business — Audience & Salary",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["tax", "business"],
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": {
          "query": "label_values(tax_web_calc_attempts_total, region)"
        },
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Total calculations (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "round(sum(increase(tax_web_calc_attempts_total[24h])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Success rate (%)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "(sum(rate(tax_web_calc_success_total[15m])) / sum(rate(tax_web_calc_attempts_total[15m]))) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "unit": "percent",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        }
      }
    },
    {
      "type": "barchart",
      "title": "Calculations by region",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(tax_web_calc_attempts_total[15m])) by (region)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Salary distribution (RUB)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(tax_web_calc_gross_salary_rub_bucket[15m])) by (le)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Median salary (p50)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(tax_web_calc_gross_salary_rub_bucket[15m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Median salary by region",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(tax_web_calc_gross_salary_rub_bucket[15m])) by (le, region))",
          "refId": "A"
        }
      ]
    }
  ]
}
